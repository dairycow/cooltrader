[Unit]
Description=CoolTrader ASX Historical Data Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hf
WorkingDirectory=/home/hf/cooltrader
ExecStart=/home/hf/cooltrader/.venv/bin/cooltrader serve --host 0.0.0.0 --port 8081
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
